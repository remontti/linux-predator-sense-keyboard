# Linux Predator Sense Keyboard
# Stable RGB symlink for Acer RGB controllers supported by this project.

# PHN16-73 and similar ENEK5130 I2C-HID controller
SUBSYSTEM=="hidraw", DEVPATH=="*0CF2:5130*", SYMLINK+="acer-rgb", MODE="0666"

# Older embedded Acer keyboard controller
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1025", ATTRS{idProduct}=="174b", SYMLINK+="acer-rgb", MODE="0666"
